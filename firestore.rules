rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Kullanıcı profillerine sadece sahip erişebilir
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Giriş yapmış kullanıcılar tüm koleksiyonlara erişebilir
    // Üretim ortamında rol bazlı kısıtlama ekleyin
    match /products/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /rawMaterials/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /formulas/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /customers/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /orders/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /shipments/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /productionLogs/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /systemTests/{docId} {
      allow read, write: if request.auth != null;
    }

    match /backups/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
